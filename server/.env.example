# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lahmanison?schema=public"

# Server
PORT=3001
NODE_ENV=development

# Auth — change this to a long random string in production (e.g. `openssl rand -hex 32`).
# In production the server refuses to start if this is left as the placeholder below.
JWT_SECRET="lahmanison-dev-jwt-secret-change-in-production"

# Client origin (for CORS). Leave UNSET in the single-origin production
# deployment, where the API also serves the built SPA. Set it only when the
# client runs on a different origin (e.g. the Vite dev server).
CLIENT_URL=http://localhost:5173

# ─── File storage ────────────────────────────────────────
# 'local' (default) writes uploads to <server>/uploads on disk.
# 's3' uses S3-compatible object storage (recommended for production).
STORAGE_DRIVER=local

# Only required when STORAGE_DRIVER=s3. Works with AWS S3, Cloudflare R2,
# Backblaze B2, MinIO, etc.
S3_BUCKET=
S3_REGION=auto
# Provider endpoint. Leave empty for AWS S3. For Cloudflare R2:
#   https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to true for MinIO / gateways that require path-style addressing.
S3_FORCE_PATH_STYLE=false
