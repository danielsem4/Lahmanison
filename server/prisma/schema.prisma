// Prisma schema — learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum PatientStatus {
  PENDING
  IN_TREATMENT
  DISCHARGED
}

// ─── User ────────────────────────────────────────────────

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  firstName    String?
  lastName     String?
  phone        String?
  hashPassword String
  role         Role    @default(AGENT)
  isActive     Boolean @default(true)

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Item (example CRUD entity) ──────────────────────────

model Item {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ─── Patient ─────────────────────────────────────────────

model Patient {
  id         Int           @id @default(autoincrement())
  firstName  String
  lastName   String
  name       String // "firstName lastName", kept in sync like User.name
  email      String
  phone      String
  age        Int
  hasImage   Boolean       @default(false)
  status     PatientStatus @default(PENDING)
  statusNote String? // free-text status detail

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
