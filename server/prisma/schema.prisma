// Prisma schema — learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum PatientStatus {
  PENDING
  IN_TREATMENT
  DISCHARGED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AppointmentType {
  MEETING
  PHONE_CALL
}

enum TaskStatus {
  OPEN
  DONE
}

// ─── User ────────────────────────────────────────────────

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  firstName    String?
  lastName     String?
  phone        String?
  hashPassword String
  role         Role    @default(AGENT)
  isActive     Boolean @default(true)

  items               Item[]
  createdPatients     Patient[]     @relation("PatientCreator")
  createdAppointments Appointment[] @relation("AppointmentCreator")
  createdTasks        Task[]        @relation("TaskCreator")
  uploadedFiles       PatientFile[] @relation("FileUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Item (example CRUD entity) ──────────────────────────

model Item {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ─── Patient ─────────────────────────────────────────────

model Patient {
  id         Int           @id @default(autoincrement())
  firstName  String
  lastName   String
  name       String // "firstName lastName", kept in sync like User.name
  email      String
  phone      String
  age        Int
  hasImage   Boolean       @default(false)
  status     PatientStatus @default(PENDING)
  statusNote String? // free-text status detail

  // The user (typically an AGENT) who created this patient. Nullable so existing
  // rows and seed data survive; SetNull keeps patients if the creator is deleted.
  createdById Int?
  createdBy   User? @relation("PatientCreator", fields: [createdById], references: [id], onDelete: SetNull)

  appointments Appointment[]
  tasks        Task[]
  files        PatientFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ─── Appointment ─────────────────────────────────────────

model Appointment {
  id          Int               @id @default(autoincrement())
  patientId   Int
  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  type        AppointmentType   @default(MEETING)
  status      AppointmentStatus @default(SCHEDULED)
  note        String? // free-text detail

  // The user (typically an AGENT) who scheduled this appointment.
  createdById Int?
  createdBy   User? @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([createdById])
}

// ─── Task (follow-up) ────────────────────────────────────

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(OPEN)

  // Optional patient this task relates to.
  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  // The user (typically an AGENT) who created this task.
  createdById Int?
  createdBy   User? @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([createdById])
}

// ─── PatientFile (uploaded documents) ────────────────────

model PatientFile {
  id        Int     @id @default(autoincrement())
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  fileName   String // original name shown to the user
  storageKey String // adapter-relative key (local: "patients/<id>/<uuid>")
  mimeType   String
  size       Int // bytes

  // The user who uploaded the file. Nullable so files survive if the uploader is deleted.
  uploadedById Int?
  uploadedBy   User? @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([uploadedById])
}
