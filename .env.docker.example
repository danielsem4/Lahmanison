# Environment for `docker compose up`. Copy to .env and fill in values.

# Postgres password (used to build DATABASE_URL for the app container).
POSTGRES_PASSWORD=postgres

# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=

# File storage: 'local' (persisted to the uploads volume) or 's3'.
STORAGE_DRIVER=local

# Only needed when STORAGE_DRIVER=s3 (AWS S3 / Cloudflare R2 / MinIO / ...).
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
